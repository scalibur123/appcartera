    <button class="filter-btn" id="df-ING" onclick="fD('ING',this)">ING</button>
    <button class="filter-btn" id="df-R4" onclick="fD('R4',this)">R4</button>
    <button class="filter-btn" id="df-IBKR" onclick="fD('IBKR',this)">IBKR</button>
  </div>
  <div class="list-count" id="d-count"></div>
  <div class="list-card" id="d-list"><div class="empty">Cargando…</div></div>
</div>

<div id="mensual" class="section">
