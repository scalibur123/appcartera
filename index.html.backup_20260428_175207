  <div class="filters">
    <button class="filter-btn active" id="cf-all" onclick="fC('all',this)">Todos</button>
    <button class="filter-btn" id="cf-EUR" onclick="fC('EUR',this)">€</button>
    <button class="filter-btn" id="cf-USD" onclick="fC('USD',this)">$</button>
    <button class="filter-btn" id="cf-ING" onclick="fC('ING',this)">ING</button>
    <button class="filter-btn" id="cf-R4" onclick="fC('R4',this)">R4</button>
    <button class="filter-btn" id="cf-IBKR" onclick="fC('IBKR',this)">IBKR</button>
  </div>
  <div class="list-count" id="c-count"></div>
  <div class="list-card" id="c-list"><div class="empty">Cargando…</div></div>
</div>

<div id="diana" class="section">
  <div class="filters">
    <button class="filter-btn active" id="df-all" onclick="fD('all',this)">Todos</button>
