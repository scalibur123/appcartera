let prices={}, cFilter='all', dFilter='all', busy=false;
let eurUsd=null;
function yT(i){return i.moneda==='EUR'?(i.tckr+(SFX[i.tckr]||'')):i.tckr;}
function dbg(msg){const el=document.getElementById('dbg');if(el)el.textContent=msg;}
function setProg(p,done=false){const el=document.getElementById('prog');el.style.width=p+'%';el.className='progress-fill'+(done?' done':'');}
function setStatus(s,t){document.getElementById('sdot').className='dot '+s;document.getElementById('stxt').textContent=t;}

async function fetchBatch(tickers){
  const symbols=tickers.join(',');
  try{
    const r=await fetch(`/?symbols=${encodeURIComponent(symbols)}`,{signal:AbortSignal.timeout(15000)});
    const data=await r.json();
    const out={};
    for(const q of (data?.quoteResponse?.result||[])) out[q.symbol]={price:q.regularMarketPrice,pct:q.regularMarketChangePercent||0};
    return out;
  }catch(e){dbg('Error: '+e.message);return {};}
}

async function startLoad(){
  if(busy)return;
  busy=true; prices={};
  setStatus('loading','Cargando precios…');
  setProg(5);
  dbg('Conectando con servidor…');

  const allY=C.map(yT);
  // Pedir cambio EUR/USD
  try{
    const fxRes=await fetchBatch(['EURUSD=X']);
    if(fxRes && fxRes['EURUSD=X']){
      eurUsd=fxRes['EURUSD=X'].price;
      const fxEl=document.getElementById('eurusd-display');
      if(fxEl) fxEl.textContent='Cambio EUR/USD: '+eurUsd.toFixed(4);
    }
  }catch(e){console.error('Error EURUSD',e);}
  const BATCH=15;
  let combined={};

  for(let i=0;i<allY.length;i+=BATCH){
    const batch=allY.slice(i,i+BATCH);
    dbg(`Cargando ${i+1}-${Math.min(i+BATCH,allY.length)} de ${allY.length}…`);
    const res=await fetchBatch(batch);
    Object.assign(combined,res);
    setProg(5+Math.round((i+BATCH)/allY.length*90));
    setStatus('loading',`${Object.keys(combined).length}/${C.length}`);
  }

  for(const item of C){const yt=yT(item);if(combined[yt])prices[item.tckr]=combined[yt];}

  const n=Object.keys(prices).length;
  setProg(100,true);
  setTimeout(()=>setProg(0),1500);

  if(n===0){
    setStatus('error','Error al cargar precios');
    dbg('ERROR: No se pudieron cargar precios. Pulsa ↻ para reintentar.');
  }else{
    const now=new Date();
    setStatus('ok',`${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')} · ${n}/${C.length}`);
    dbg(`✓ ${n} precios cargados`);
  }
  busy=false;
  updateResumen();renderCartera();renderDiana();
}

function fE(n){return n.toLocaleString('es-ES',{minimumFractionDigits:2,maximumFractionDigits:2})+' €';}
function fN(n,d=2){return n.toLocaleString('es-ES',{minimumFractionDigits:d,maximumFractionDigits:d});}
function sg(n){return n>=0?'+':'';}
function aC(el,t){let v=0;const s=Math.max(1,Math.ceil(t/18));const fn=()=>{v=Math.min(v+s,t);el.textContent=v;if(v<t)requestAnimationFrame(fn);};requestAnimationFrame(fn);}

function updateResumen(){
  let b=0;
  for(const i of C){const p=prices[i.tckr];if(p){const pe=i.moneda==='USD'&&eurUsd?p.price/eurUsd:p.price;b+=i.titulos*pe-i.coste_eur;}}
  const n=b*(1-0.20925);
  const pb=document.getElementById('pv-b'),pn=document.getElementById('pv-n');
  pb.textContent=fE(b);pb.style.color=b>=0?'var(--green)':'var(--red)';
  pn.textContent=fE(n);pn.style.color=n>=0?'var(--green)':'var(--red)';
  const wo=C.filter(i=>i.objetivo&&prices[i.tckr]);
  aC(document.getElementById('cnt-neg'),wo.filter(i=>prices[i.tckr].price>=i.objetivo).length);
  aC(document.getElementById('cnt-warn'),wo.filter(i=>{const d=(i.objetivo-prices[i.tckr].price)/i.objetivo;return d>=0&&d<=0.07;}).length);
}

function showTab(id,btn){document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');btn.classList.add('active');}
function goToDiana(f){document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));document.querySelectorAll('.nav-btn')[2].classList.add('active');document.getElementById('diana').classList.add('active');document.querySelectorAll('[id^="df-"]').forEach(b=>b.classList.remove('active'));document.getElementById('df-'+f).classList.add('active');dFilter=f;renderDiana();}
function fC(f,btn){cFilter=f;document.querySelectorAll('[id^="cf-"]').forEach(b=>b.classList.remove('active'));btn.classList.add('active');renderCartera();}
function fD(f,btn){dFilter=f;document.querySelectorAll('[id^="df-"]').forEach(b=>b.classList.remove('active'));btn.classList.add('active');renderDiana();}

function renderCartera(){
  const s=document.getElementById('csearch').value.trim().toUpperCase();
  const data=C.filter(i=>{
    if(s&&!i.tckr.includes(s))return false;
    if(cFilter==='EUR')return i.moneda==='EUR';
    if(cFilter==='USD')return i.moneda==='USD';
    if(cFilter==='ING')return i.banco.toUpperCase().includes('ING');
    if(cFilter==='R4')return i.banco.toUpperCase().includes('R4');
    if(cFilter==='IBKR')return i.banco.toUpperCase().includes('IBKR');
    return true;
  });
  document.getElementById('c-count').textContent=data.length+' valores';
  document.getElementById('c-list').innerHTML=data.map(item=>{
    const p=prices[item.tckr];
    const ps=p?fN(p.price):'—';
    const pcs=p?(sg(p.pct)+fN(p.pct)+'%'):'';
    const pcc=p?(p.pct>=0?'var(--green)':'var(--red)'):'var(--muted)';
    let pms='',pmc='';
    if(p){const pe=item.moneda==='USD'&&eurUsd?p.price/eurUsd:p.price;const pm=item.titulos*pe-item.coste_eur;pms=(pm>=0?'+':'')+fE(pm);pmc=pm>=0?'pos':'loss';}
    return`<div class="list-row"><div class="row-left"><span class="tckr">${item.tckr} <span style="font-size:10px;color:var(--muted)">${item.moneda==='EUR'?'€':'$'}</span></span><span class="banco-pill">${item.banco}</span></div><div class="row-right"><span class="price-val normal">${ps} <span style="font-size:10px;color:${pcc}">${pcs}</span></span>${p?`<span class="pill ${pmc}">${pms}</span>`:'<span style="font-size:10px;color:var(--muted)">—</span>'}<span class="price-sub">Obj.${item.objetivo?fN(item.objetivo):'—'} · Med.${fN(item.precio_medio)}</span></div></div>`;
  }).join('');
}

function renderDiana(){
  let data=C.filter(i=>i.objetivo).filter(item=>{
    const p=prices[item.tckr]?.price;
    if(dFilter==='neg')return p!=null&&p>=item.objetivo;
    if(dFilter==='warn'){if(!p)return false;const d=(item.objetivo-p)/item.objetivo;return d>=0&&d<=0.07;}
    if(dFilter==='ING')return item.banco.toUpperCase().includes('ING');
    if(dFilter==='R4')return item.banco.toUpperCase().includes('R4');
    if(dFilter==='IBKR')return item.banco.toUpperCase().includes('IBKR');
    return true;
  });
  data.sort((a,b)=>{const pa=prices[a.tckr]?.price,pb=prices[b.tckr]?.price;const da=pa?(pa-a.objetivo)/a.objetivo:-999,db=pb?(pb-b.objetivo)/b.objetivo:-999;return db-da;});
  document.getElementById('d-count').textContent=data.length+' valores';
  document.getElementById('d-list').innerHTML=data.map(item=>{
    const p=prices[item.tckr];const price=p?.price;
    const atO=price!=null&&price>=item.objetivo;
    const dist=price!=null?(item.objetivo-price)/item.objetivo:null;
    const nearO=dist!=null&&dist>=0&&dist<=0.07;
    const ps=price!=null?fN(price):'—';
    const pcs=p?(sg(p.pct)+fN(p.pct)+'%'):'';
    const pcc=p?(p.pct>=0?'var(--green)':'var(--red)'):'var(--muted)';
    let ds='',dc='';
    if(price!=null){const d=(price-item.objetivo)/item.objetivo*100;ds=(d>=0?'+':'')+fN(d)+'% obj';dc=d>=0?'pos':'neg';}
    return`<div class="list-row"><div class="row-left"><span class="tckr">${item.tckr}</span><span class="banco-pill">${item.banco}</span></div><div class="row-right"><span class="price-val ${atO?'at-obj':nearO?'near-obj':'normal'}">${ps} <span style="font-size:10px;color:${pcc}">${pcs}</span></span>${price!=null?`<span class="pill ${dc}">${ds}</span>`:'<span style="font-size:10px;color:var(--muted)">—</span>'}<span class="price-sub">Obj. ${fN(item.objetivo)}</span></div></div>`;
  }).join('');
}

startLoad();
</script>
</body>
</html>
