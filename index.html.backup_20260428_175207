<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="AppCartera">
<meta name="theme-color" content="#0e0f11">
<title>AppCartera</title>
<style>
:root{--bg:#0e0f11;--surface:#16181c;--surface2:#1e2026;--border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);--text:#f0f0f0;--muted:#6b7280;--green:#22c55e;--green-dim:rgba(34,197,94,0.1);--green-border:rgba(34,197,94,0.25);--amber:#f59e0b;--amber-dim:rgba(245,158,11,0.1);--amber-border:rgba(245,158,11,0.25);--red:#ef4444;--red-dim:rgba(239,68,68,0.08)}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;max-width:430px;margin:0 auto;padding-bottom:90px;-webkit-font-smoothing:antialiased}
.header{padding:52px 18px 14px;display:flex;justify-content:space-between;align-items:flex-end;border-bottom:1px solid var(--border)}
.header-title{font-size:11px;letter-spacing:.12em;color:var(--muted);text-transform:uppercase;font-weight:500}
.header-status{font-size:12px;color:var(--muted);display:flex;align-items:center;gap:6px;margin-top:4px}
.dot{width:7px;height:7px;border-radius:50%;background:var(--muted);display:inline-block;flex-shrink:0}
.dot.loading{background:var(--amber);animation:pulse 1s ease-in-out infinite}
.dot.ok{background:var(--green)}
.dot.error{background:var(--red)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.2}}
.refresh-btn{background:var(--surface2);border:1px solid var(--border2);border-radius:10px;color:var(--muted);font-size:13px;padding:8px 14px;cursor:pointer;font-weight:500}
.progress-bar{height:2px}
.progress-fill{height:2px;background:var(--amber);width:0%;transition:width .3s ease}
.progress-fill.done{background:var(--green)}
.nav{display:flex;padding:10px 18px;gap:6px;border-bottom:1px solid var(--border);background:var(--bg);position:sticky;top:0;z-index:10}
.nav-btn{flex:1;padding:9px 4px;background:transparent;border:1px solid transparent;border-radius:10px;color:var(--muted);font-size:12px;cursor:pointer;transition:all .2s}
.nav-btn.active{background:var(--surface2);border-color:var(--border);color:var(--text);font-weight:500}
.section{display:none;padding:14px 18px}
.section.active{display:block}
.card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:14px 16px;margin-bottom:10px}
.card-label{font-size:10px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;margin-bottom:14px;font-weight:500}
.plusv-row{display:flex;justify-content:space-between;align-items:baseline;padding:10px 0;border-bottom:1px solid var(--border)}
.plusv-row:last-child{border-bottom:none}
.plusv-label{font-size:13px;color:var(--muted)}
.plusv-val{font-size:20px;font-weight:500}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.stat{border-radius:16px;padding:16px 14px;cursor:pointer;border:1px solid transparent}
.stat.green-s{background:var(--green-dim);border-color:var(--green-border)}
.stat.amber-s{background:var(--amber-dim);border-color:var(--amber-border)}
.stat-label{font-size:11px;color:var(--muted);margin-bottom:8px}
.stat-num{font-size:52px;font-weight:600;line-height:1;letter-spacing:-.03em}
.stat-num.green{color:var(--green)}
.stat-num.amber{color:var(--amber)}
.stat-hint{font-size:10px;color:var(--muted);margin-top:8px}
.filters{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.filter-btn{padding:7px 12px;background:var(--surface);border:1px solid var(--border);border-radius:20px;color:var(--muted);font-size:12px;cursor:pointer;white-space:nowrap}
.filter-btn.active{background:var(--surface2);border-color:var(--border2);color:var(--text);font-weight:500}
.search-wrap{position:relative;margin-bottom:12px}
.search-input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:12px;color:var(--text);font-size:15px;padding:10px 14px 10px 38px;outline:none;-webkit-appearance:none}
.search-input::placeholder{color:var(--muted)}
.search-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--muted);font-size:15px;pointer-events:none}
.list-count{font-size:11px;color:var(--muted);margin-bottom:10px}
.list-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;overflow:hidden}
.list-row{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-bottom:1px solid var(--border)}
.list-row:last-child{border-bottom:none}
.row-left{display:flex;flex-direction:column;gap:5px;min-width:0}
.row-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;margin-left:10px}
.tckr{font-size:14px;font-weight:600;color:var(--text)}
.banco-pill{font-size:10px;padding:2px 8px;border-radius:10px;background:var(--surface2);color:var(--muted);border:1px solid var(--border);width:fit-content}
.price-val{font-size:14px;font-weight:500}
.price-val.at-obj{color:var(--green)}
.price-val.near-obj{color:var(--amber)}
.price-val.normal{color:var(--text)}
.price-sub{font-size:10px;color:var(--muted);text-align:right}
.pill{font-size:10px;padding:3px 8px;border-radius:8px;font-weight:500}
.pill.pos{background:var(--green-dim);color:var(--green)}
.pill.neg{background:var(--amber-dim);color:var(--amber)}
.pill.loss{background:var(--red-dim);color:var(--red)}
.mensual-val{font-size:20px;font-weight:500}
.mensual-val.green{color:var(--green)}
.empty{text-align:center;padding:30px 0;color:var(--muted);font-size:13px}
.note{font-size:11px;color:var(--muted);margin-top:10px;line-height:1.7}
.dbg{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 14px;font-size:11px;color:var(--muted);margin-bottom:10px;font-family:monospace;line-height:1.6}
</style>
</head>
